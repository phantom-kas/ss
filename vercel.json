{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "routes": [
    { "src": "/(.*\\..*)", "dest": "/$1" },      // Serve static files normally
    { "src": "/(.*)", "dest": "/index.html" }    // All other routes go to index.html
  ]
}
